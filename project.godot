; Engine configuration file.
; Edit through Godot when possible.

config_version=5

[application]

config/name="Shrugame"
config/version="1.0.6"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.0")

[autoload]

GameState="*res://scripts/core/game_state.gd"
DialogueManager="*res://scripts/dialogue/dialogue_manager.gd"
SaveSystem="*res://scripts/core/save_system.gd"
SettingsManager="*res://scripts/core/settings_manager.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
PresentationGuide="*res://scripts/visual/presentation_guide.gd"
CutsceneDirector="*res://scripts/cutscenes/cutscene_director.gd"
InputManager="*res://scripts/core/input_manager.gd"
InteractionManager="*res://scripts/overworld/interaction_manager.gd"
TutorialManager="*res://scripts/core/tutorial_manager.gd"
LevelManager="*res://scripts/core/level_manager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/size/min_width=960
window/size/min_height=540
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"

[gui]

theme/custom="res://assets/shared/ui/shrugame_theme.tres"

[audio]

default_bus_layout="res://default_bus_layout.tres"

[rendering]

textures/canvas_textures/default_texture_filter=0

